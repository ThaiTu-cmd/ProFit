# Copy to .env at project root before running API or ingest.

# --- Required for chat + embeddings ---
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-5-nano
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Required for production retrieval (PGVector) ---
PGVECTOR_CONNECTION=postgresql+psycopg://langchain:langchain@localhost:6024/langchain
PGVECTOR_COLLECTION=my_docs

# --- Optional: LangSmith tracing ---
# LANGCHAIN_TRACING_V2=false
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=

# --- Optional: chat / reflection ---
# CHAT_TRIM_MAX_TOKENS=2000
# CHAT_HISTORY_MAX_TURNS=12
# ENABLE_REFLECTION=false
# REFLECTION_MAX_ITERATIONS=3

# --- Optional: admin token usage in /chat responses ---
# ADMIN_USER_IDS=1

# --- Optional: local UI without Postgres (single demo doc per route; NOT production) ---
# ALLOW_DEMO_RETRIEVER=false

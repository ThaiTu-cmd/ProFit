# ========================================
# FILE BIẾN MÔI TRƯỜNG - ProFit (Backend)
# ========================================
# Copy file này thành .env và điền giá trị thực tế
# File .env sẽ KHÔNG bị push lên git (đã có trong .gitignore)

# ========== DATABASE ==========
DB_URL=jdbc:mysql://localhost:3306/ProFitSuppsDB?createDatabaseIfNotExist=true&useUnicode=true&characterEncoding=UTF-8&serverTimezone=Asia/Ho_Chi_Minh&connectionCharacterSet=UTF-8
DB_USERNAME=root
DB_PASSWORD=your_mysql_password

# ========== JWT ==========
JWT_SECRET=your_jwt_secret_key_must_be_at_least_64_characters_long
JWT_EXPIRATION_MS=86400000
JWT_REMEMBER_EXPIRATION_MS=604800000

# ========== FRONTEND BASE URL ==========
FRONTEND_BASE_URL=http://localhost:5173

# ========== VNPAY (Payment Gateway) ==========
# Đăng ký tài khoản VNPAY Sandbox tại: https://sandbox.vnpayment.vn/
VNPAY_TMN_CODE=your_vnpay_tmn_code
VNPAY_HASH_SECRET=your_vnpay_hash_secret
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:5173/vnpay-return
VNPAY_IPN_URL=http://localhost:8080/ProFitSuppsDB/api/v1/vnpay/ipn
VNPAY_MODE=sandbox

# ========== ADMIN BOOTSTRAP (Default admin account) ==========
BOOTSTRAP_ADMIN_ENABLED=true
BOOTSTRAP_ADMIN_EMAIL=admin@profit.com
BOOTSTRAP_ADMIN_PASSWORD=change_this_password_after_first_login
BOOTSTRAP_ADMIN_FULL_NAME=Administrator
BOOTSTRAP_ADMIN_PHONE=0123456789

BOOTSTRAP_CUSTOMER_ENABLED=true
BOOTSTRAP_CUSTOMER_EMAIL=khachhang@gmail.com
BOOTSTRAP_CUSTOMER_PASSWORD=Customer@123
BOOTSTRAP_CUSTOMER_FULL_NAME=Khách Hàng Test
BOOTSTRAP_CUSTOMER_PHONE=0987654321
